# LingBot-MAP Spatial Memory — Environment Variables
# Copy to .env and customize for your deployment

# Root directory (all other paths derive from this)
STMEM_HOME=/home/orin/lingbot-map-stmem

# Data directories
# STMEM_DATA_DIR=$STMEM_HOME/data
# STMEM_DATASAVE_DIR=$STMEM_HOME/datasave

# Model paths
# STMEM_MODEL_PATH=$STMEM_HOME/checkpoints/lingbot-map-long.pt
# STMEM_DAV2_MODEL=depth-anything/Depth-Anything-V2-Metric-Indoor-Large-hf

# DGSG pipeline
# STMEM_DGSG_DIR=$STMEM_HOME/backend/dgsg
# STMEM_DGSG_EXP_DIR=$STMEM_HOME/backend/dgsg/experiments/mydata
# STMEM_DGSG_MODEL_DIR=$STMEM_HOME/models
# STMEM_DGSG_SCENE=lingbot

# Python environment
# STMEM_CONDA_PYTHON=/home/orin/miniconda3/envs/dgsg/bin/python3

# HuggingFace mirror (for China)
HF_ENDPOINT=https://hf-mirror.com
